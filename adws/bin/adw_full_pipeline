#!/usr/bin/env ruby
# frozen_string_literal: true

#
# ADW Full Pipeline - AI Developer Workflow (ADW)
#
# Usage: adw_full_pipeline <github-issue-number> [adw-id]
#
# Workflow:
# 1. Plan & Build (classify, create branch, plan, implement)
# 2. Test with automatic failure resolution (up to 4 attempts)
# 3. Technical code review with auto-fix of critical issues (up to 2 attempts)
# 4. Visual review against issue with screenshot evidence (non-blocking)
# 5. Documentation generation (non-blocking)
# 6. Commit all changes
# 7. Create pull request
#
# Stops with error if tests fail or review finds unresolvable critical issues.
#

require "bundler/setup"
require_relative "../lib/adw"

if ARGV.length < 1
  puts "Usage: adw_full_pipeline <issue-number> [adw-id]"
  puts "Example: adw_full_pipeline 123"
  puts "Example: adw_full_pipeline 123 abc12345"
  exit 1
end

issue_number = ARGV[0]
adw_id = ARGV[1] || Adw::Utils.make_adw_id

logger = Adw::Utils.setup_logger(issue_number, adw_id, "adw_full_pipeline")
logger.info("ADW Full Pipeline - ID: #{adw_id}")

result = Adw::Workflows::FullPipeline.result(
  issue_number: issue_number,
  adw_id: adw_id,
  logger: logger
)

unless result.success?
  logger.error("Pipeline failed: #{result.error}")
  exit 1
end

logger.info("ADW full pipeline completed for issue ##{issue_number}")
