#!/usr/bin/env ruby
# frozen_string_literal: true

#
# ADW Plan, Build & Test - AI Developer Workflow (ADW)
#
# Usage: adw_plan_build_test <github-issue-number> [adw-id]
#
# Workflow:
# 1. Plan & Build (classify, create branch, plan, implement)
# 2. Run tests with automatic failure resolution (up to 4 attempts)
# 3. Commit any test fixes and push
#
# Stops with error if tests fail after all retry attempts.
#

require "bundler/setup"
require_relative "../lib/adw"

if ARGV.length < 1
  puts "Usage: adw_plan_build_test <issue-number> [adw-id]"
  puts "Example: adw_plan_build_test 123"
  puts "Example: adw_plan_build_test 123 abc12345"
  exit 1
end

issue_number = ARGV[0]
adw_id = ARGV[1] || Adw::Utils.make_adw_id

logger = Adw::Utils.setup_logger(issue_number, adw_id, "adw_plan_build_test")
logger.info("ADW Plan Build Test - ID: #{adw_id}")

result = Adw::Workflows::PlanBuildTest.result(
  issue_number: issue_number,
  adw_id: adw_id,
  logger: logger
)

unless result.success?
  logger.error("Pipeline failed: #{result.error}")
  exit 1
end

logger.info("ADW plan, build & test completed for issue ##{issue_number}")
